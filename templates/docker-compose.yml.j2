services:
  3x-ui:
    image: ghcr.io/mhsanaei/3x-ui:latest
    container_name: 3x-ui
    hostname: {{ inventory_hostname }}
    network_mode: host
    tty: true
    stdin_open: true
    restart: unless-stopped
    environment:
      - XRAY_VMESS_AEAD_FORCED=false
      - TZ=UTC
    volumes:
      - {{ install_dir }}/db:/etc/x-ui
      - {{ install_dir }}/cert:/root/cert
      - {{ install_dir }}/xray:/app/bin
